###############################################################################
#  Snakefile — RZ vs RZK snMultiome Analysis Pipeline
#  
#  10x Genomics snMultiome (snRNA-seq + scATAC-seq) analysis with
#  Seurat v4 + Signac, reproducing the workflow from:
#  "Epithelial WNT secretion drives niche escape of developing gastric cancer"
#
#  Steps:
#    1. create_objects    — Load 10x .h5, build Seurat multiome objects
#    2. qc_filter         — Quality control & cell filtering
#    3. macs2_peaks       — MACS2 peak calling + blacklist removal
#    4. process_rna       — SCTransform + LogNormalize + variable features
#    5. process_atac      — TF-IDF + SVD on 10x & MACS2 peaks
#    6. integrate         — SCT-based anchor integration (WT + Mutant)
#    7. cluster           — PCA → UMAP → clustering (res 0.3 & 0.6)
#    8. deg_analysis      — DEG (MAST) + KRAS hallmark overlap
#    9. visualize         — Figures 3A-3I, S3A-S3C
#   10. da_motif          — Differential accessibility + motif enrichment
###############################################################################

configfile: "config.yaml"

# Final outputs expected by the pipeline
rule all:
    input:
        # Core analysis outputs
        "/output/clustered_object.rds",
        "/output/RZRZK_DEG_scMAST.csv",
        # Visualisation outputs (figures)
        "/output/figures/fig_3A_UMAP.pdf",
        "/output/figures/fig_3B_dotplot.pdf",
        "/output/figures/fig_3C_dittobarplot.pdf",
        "/output/figures/fig_3D_Wnt7b_feature.pdf",
        "/output/figures/fig_3E_Wnt7b_pct.pdf",
        "/output/figures/fig_3H_linkage_coverage.pdf",
        "/output/figures/fig_3I_motifs_Wnt_vs_Lgr5_RZK.pdf",
        "/output/figures/fig_S3C_motifs_Wnt_vs_Lgr5_RZ.pdf",
        "/output/figures/fig_S3B_Wnt_family.pdf",
        # DA + motif outputs
        "/output/da_peaks_mutant.csv",
        "/output/da_peaks_wildtype.csv"


# --------------------------------------------------------------------------
# Step 1-5: Create objects, QC, MACS2, RNA + ATAC processing (per sample)
# --------------------------------------------------------------------------
rule process_sample:
    """Load 10x data, QC filter, MACS2 peak calling, RNA & ATAC processing."""
    input:
        h5       = lambda wc: "/input/" + config["samples"][wc.sample]["h5"],
        fragments= lambda wc: "/input/" + config["samples"][wc.sample]["fragments"],
        metadata = lambda wc: "/input/" + config["samples"][wc.sample]["metadata"]
    output:
        rds = "/output/processed_{sample}.rds"
    params:
        species   = config["species"],
        genotype  = lambda wc: config["samples"][wc.sample]["genotype"],
        qc        = config["qc"],
        nfeatures = config["rna"]["n_variable_features"],
        macs2     = config["macs2_path"]
    threads: config.get("threads", 20)
    log:
        "/output/logs/{sample}_process.log"
    shell:
        """
        Rscript /pipeline/scripts/01_process_sample.R \
            --h5 {input.h5} \
            --fragments {input.fragments} \
            --metadata {input.metadata} \
            --species {params.species} \
            --genotype {params.genotype} \
            --nCount_ATAC_min {params.qc[nCount_ATAC_min]} \
            --nCount_ATAC_max {params.qc[nCount_ATAC_max]} \
            --nCount_RNA_min {params.qc[nCount_RNA_min]} \
            --nCount_RNA_max {params.qc[nCount_RNA_max]} \
            --nucleosome_signal_max {params.qc[nucleosome_signal_max]} \
            --TSS_enrichment_min {params.qc[TSS_enrichment_min]} \
            --percent_mt_max {params.qc[percent_mt_max]} \
            --nfeatures {params.nfeatures} \
            --macs2_path {params.macs2} \
            --threads {threads} \
            --max_memory_gb {config[max_memory_gb]} \
            --output {output.rds} \
            2>&1 | tee {log}
        """

# --------------------------------------------------------------------------
# Step 6-7: Integration + Clustering
# --------------------------------------------------------------------------
rule integrate_and_cluster:
    """SCT integration of WT + Mutant, PCA, UMAP, clustering (res 0.3 & 0.6)."""
    input:
        wild   = "/output/processed_wild.rds",
        mutant = "/output/processed_mutant.rds"
    output:
        rds = "/output/clustered_object.rds"
    params:
        npcs       = config["clustering"]["npcs"],
        dims       = config["clustering"]["dims"],
        res_init   = config["clustering"]["resolution_initial"],
        res_refine = config["clustering"]["resolution_refine"],
        algorithm  = config["clustering"]["algorithm"]
    threads: config.get("threads", 20)
    log:
        "/output/logs/integrate_cluster.log"
    shell:
        """
        Rscript /pipeline/scripts/02_integrate_cluster.R \
            --wild {input.wild} \
            --mutant {input.mutant} \
            --npcs {params.npcs} \
            --dims {params.dims} \
            --resolution_initial {params.res_init} \
            --resolution_refine {params.res_refine} \
            --algorithm {params.algorithm} \
            --threads {threads} \
            --max_memory_gb {config[max_memory_gb]} \
            --output {output.rds} \
            2>&1 | tee {log}
        """

# --------------------------------------------------------------------------
# Step 8: Differential Expression (MAST) + KRAS Hallmark
# --------------------------------------------------------------------------
rule deg_analysis:
    """DEG (Mutant vs WT) using MAST; overlap with HALLMARK_KRAS_SIGNALING_UP."""
    input:
        rds = "/output/clustered_object.rds"
    output:
        csv = "/output/RZRZK_DEG_scMAST.csv"
    params:
        test     = config["de"]["test_use"],
        padj     = config["de"]["padj_threshold"],
        log2fc   = config["de"]["log2fc_threshold"]
    threads: config.get("threads", 20)
    log:
        "/output/logs/deg_analysis.log"
    shell:
        """
        Rscript /pipeline/scripts/03_deg_analysis.R \
            --input {input.rds} \
            --test_use {params.test} \
            --padj_threshold {params.padj} \
            --log2fc_threshold {params.log2fc} \
            --output {output.csv} \
            --threads {threads} \
            --max_memory_gb {config[max_memory_gb]} \
            2>&1 | tee {log}
        """

# --------------------------------------------------------------------------
# Step 9: Visualisation (Figures 3A–3E, 3H, S3A, S3B)
# --------------------------------------------------------------------------
rule visualize:
    """Generate all main and supplementary figures."""
    input:
        rds = "/output/clustered_object.rds"
    output:
        fig3a = "/output/figures/fig_3A_UMAP.pdf",
        fig3b = "/output/figures/fig_3B_dotplot.pdf",
        fig3c = "/output/figures/fig_3C_dittobarplot.pdf",
        fig3d = "/output/figures/fig_3D_Wnt7b_feature.pdf",
        fig3e = "/output/figures/fig_3E_Wnt7b_pct.pdf",
        fig3h = "/output/figures/fig_3H_linkage_coverage.pdf",
        figs3b = "/output/figures/fig_S3B_Wnt_family.pdf"
    params:
        species = config["species"],
        regions = config["wnt7b_regions"]
    threads: config.get("threads", 20)
    log:
        "/output/logs/visualize.log"
    shell:
        """
        mkdir -p /output/figures
        Rscript /pipeline/scripts/04_visualize.R \
            --input {input.rds} \
            --species {params.species} \
            --outdir /output/figures \
            --threads {threads} \
            --max_memory_gb {config[max_memory_gb]} \
            2>&1 | tee {log}
        """

# --------------------------------------------------------------------------
# Step 10: Differential Accessibility + Motif Enrichment
# --------------------------------------------------------------------------
rule da_motif:
    """DA peaks (Wnt7+ vs Lgr5+) + JASPAR motif enrichment in WT and Mutant."""
    input:
        rds = "/output/clustered_object.rds"
    output:
        da_m    = "/output/da_peaks_mutant.csv",
        da_w    = "/output/da_peaks_wildtype.csv",
        fig3i   = "/output/figures/fig_3I_motifs_Wnt_vs_Lgr5_RZK.pdf",
        figs3c  = "/output/figures/fig_S3C_motifs_Wnt_vs_Lgr5_RZ.pdf"
    params:
        species          = config["species"],
        min_pct          = config["da"]["min_pct"],
        logfc_threshold  = config["da"]["logfc_threshold"],
        test_use         = config["da"]["test_use"],
        latent_vars      = config["da"]["latent_vars"],
        padj_motif       = config["da"]["padj_threshold_motif"]
    log:
        "/output/logs/da_motif.log"
    shell:
        """
        mkdir -p /output/figures
        Rscript /pipeline/scripts/05_da_motif.R \
            --input {input.rds} \
            --species {params.species} \
            --min_pct {params.min_pct} \
            --logfc_threshold {params.logfc_threshold} \
            --test_use {params.test_use} \
            --latent_vars {params.latent_vars} \
            --padj_motif {params.padj_motif} \
            --outdir /output \
            2>&1 | tee {log}
        """